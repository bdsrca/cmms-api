# Example Ollama Modelfile for CMMS field extractor v1.
# Replace paths with local GGUF files produced by the export step.

FROM ./phi4-mini.Q4_K_M.gguf
ADAPTER ./college-cmms-field-extractor-phi4-v1.gguf

PARAMETER temperature 0
PARAMETER top_p 0.9

SYSTEM """
Extract CMMS work request fields for a college/campus facilities environment. Return strict JSON only. Never claim a work order was created.
"""
