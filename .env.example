ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-unique-password
LLM_API_KEY=replace-with-a-long-ai-api-key
LOCAL_CONTROL_API_KEY=replace-with-a-separate-local-control-key
PORTAL_COOKIE_SECURE=false

# Optional: route only CMMS field extraction to a fine-tuned local extractor.
# Set EXTRACTOR_MODEL_ENABLED=false to force OLLAMA_MODEL even when EXTRACTOR_MODEL_NAME is set.
# Leave EXTRACTOR_MODEL_NAME unset to use OLLAMA_MODEL / qwen3:8b.
EXTRACTOR_MODEL_ENABLED=true
EXTRACTOR_MODEL_NAME=phi4-mini:latest

# Optional: route classifier and draft generation to specialized local models.
CLASSIFIER_MODEL_ENABLED=true
CLASSIFIER_MODEL_NAME=
DRAFT_MODEL_ENABLED=true
DRAFT_MODEL_NAME=

# Runtime feature switches.
SAFETY_REVIEWER_ENABLED=true
AI_FAST_MODE_ENABLED=false
OLLAMA_JSON_FORMAT_ENABLED=true
CLASSIFIER_TIMEOUT_SECONDS=30
EXTRACTOR_TIMEOUT_SECONDS=60
DRAFT_TIMEOUT_SECONDS=90
REVIEWER_TIMEOUT_SECONDS=45
LOW_CONFIDENCE_REVIEW_THRESHOLD=0.75
